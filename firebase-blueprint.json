{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in LaunchIQ",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A business concept project initiated by a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "idea": { "type": "string" },
        "industry": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "budget": { "type": "string" },
        "targetCustomers": { "type": "string" },
        "stage": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "name", "idea", "industry", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "Full validation report generated by AI for a project",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "score": { "type": "integer" },
        "scoreExplanation": { "type": "string" },
        "marketAnalysis": { "type": "object" },
        "competitorAnalysis": { "type": "object" },
        "customerPersonas": { "type": "object" },
        "swotAnalysis": { "type": "object" },
        "riskAssessment": { "type": "object" },
        "revenueForecast": { "type": "object" },
        "roadmap": { "type": "object" },
        "investorSummary": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "projectId", "score", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or project notification for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "alert", "system", "success"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Audit trails and user actions on LaunchIQ",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "action", "createdAt"]
    },
    "SystemStats": {
      "title": "SystemStats",
      "description": "Platform aggregate statistics for administration",
      "type": "object",
      "properties": {
        "totalUsers": { "type": "integer" },
        "totalReports": { "type": "integer" },
        "totalProjects": { "type": "integer" },
        "activeUsersCount": { "type": "integer" },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Individual user accounts"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Business ideas and details"
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Generated assessment reports"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "In-app notifications"
    },
    "/activityLogs/{logId}": {
      "schema": { "$ref": "#/entities/ActivityLog" },
      "description": "User behavior tracking logs"
    },
    "/system/stats": {
      "schema": { "$ref": "#/entities/SystemStats" },
      "description": "Global administrator metrics and dashboard counters"
    }
  }
}
